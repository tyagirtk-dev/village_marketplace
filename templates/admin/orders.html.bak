{% extends "base.html" %}
{% block title %}Admin - Manage Orders{% endblock %}

{% block content %}
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-cart-check text-primary me-2"></i>Manage All Orders</h2>
        <span class="badge bg-primary fs-6">{{ orders.total if orders.total is defined else orders|length }} Total Orders</span>
    </div>

    <div class="card shadow-sm border rounded-4 mb-4 bg-light">
        <div class="card-body">
            <form method="GET" action="{{ url_for('admin.orders') }}" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="search" value="{{ search or '' }}" class="form-control" placeholder="Search by Order # or Customer...">
                </div>
                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="pending" {% if status == 'pending' %}selected{% endif %}>Pending</option>
                        <option value="shipped" {% if status == 'shipped' %}selected{% endif %}>Shipped</option>
                        <option value="delivered" {% if status == 'delivered' %}selected{% endif %}>Delivered</option>
                        <option value="cancelled" {% if status == 'cancelled' %}selected{% endif %}>Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Order #</th>
                        <th>Customer</th>
                        <th>Total Amount</th>
                        <th>Commission</th>
                        <th>Earnings</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% if orders.items %}
                        {% for order in orders.items %}
                        <tr>
                            <td class="ps-3 fw-bold text-secondary">#{{ order.order_number }}</td>
                            <td>{{ order.customer.user.name if order.customer else 'Unknown' }}</td>
                            <td class="fw-bold text-success">₹{{ "%.2f"|format(order.total_amount) }}</td>
                            <td class="text-danger">₹{{ "%.2f"|format(order.commission_amount) }}</td>
                            <td class="text-primary">₹{{ "%.2f"|format(order.seller_earnings) }}</td>
                            <td>
                                {% if order.status == 'pending' %}
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Pending</span>
                                {% elif order.status == 'shipped' %}
                                    <span class="badge bg-info text-dark px-3 py-2 rounded-pill">Shipped</span>
                                {% elif order.status == 'delivered' %}
                                    <span class="badge bg-success px-3 py-2 rounded-pill">Delivered</span>
                                {% else %}
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">Cancelled</span>
                                {% endif %}
                            </td>
                            <td class="text-muted" style="font-size: 0.9rem;">{{ order.created_at.strftime('%d %b %Y %H:%M') }}</td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No orders found.
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
